<div class="nested-form-wrapper d-flex gap-2 my-2" data-new-record="<%= ff.object.new_record? %>">
  <%= ff.text_field :name, class: "form-control" %>

  <button type="button" class="btn btn-danger" data-action="nested-form#remove">
    <i class="bi bi-x-circle-fill"></i>
  </button>

  <%= ff.hidden_field :_destroy %>
</div>