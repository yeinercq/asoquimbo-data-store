<%= turbo_frame_tag dom_id(custom_option_list.custom_select_list, dom_id(custom_option_list)) do %>
  <div class="border rounded px-4 py-2 mb-2 shadow">
    <div class="d-flex justify-content-between align-items-center pt-2">
      <strong><%= t("activerecord.attributes.#{custom_option_list.custom_select_list.model_name_association}.#{custom_option_list.model_field}") %></strong>
      <div class="d-flex gap-2">
        <%= link_to edit_custom_select_list_custom_option_list_path(custom_option_list.custom_select_list, custom_option_list) do %>
          <div class="btn btn-sm btn-secondary">
            <i class="bi bi-pencil"></i>
          </div>
        <% end %>
        <%= link_to custom_select_list_custom_option_list_path(custom_option_list.custom_select_list, custom_option_list), data: { turbo_method: :delete , turbo_confirm: t("common.form.confirm_delete")} do %>
          <div class="btn btn-sm btn-danger">
            <i class="bi bi-trash"></i>
          </div>
        <% end %>
      </div>
    </div>
    <hr>
    <strong>Opciones:</strong>
    <div>
      <ul class="list-group list-group-flush mt-2">
        <% custom_option_list.custom_options.ordered.each do |option| %>
          <li class="list-group-item">
            <%= option.name %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
<% end %>