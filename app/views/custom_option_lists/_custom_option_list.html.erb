<li class="list-group-item d-flex justify-content-between align-items-center">
  <%= t("activerecord.attributes.#{custom_option_list.custom_select_list.model_name_association}.#{custom_option_list.model_field}") %>
  <div class="d-flex gap-2">
    <%= link_to edit_custom_select_list_custom_option_list_path(custom_option_list.custom_select_list, custom_option_list), data: { turbo: false } do %>
      <div class="btn btn-sm btn-secondary">
        <i class="bi bi-pencil"></i>
      </div>
    <% end %>
    <%= link_to custom_select_list_custom_option_list_path(custom_option_list.custom_select_list, custom_option_list), data: { turbo_method: :delete , turbo_confirm: t("common.form.confirm_delete")} do %>
      <div class="btn btn-sm btn-danger">
        <i class="bi bi-trash"></i>
      </div>
    <% end %>
  </div>
</li>