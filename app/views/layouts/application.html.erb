<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Asoquimbo Data Store" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>
  <body>
    <% if user_signed_in? %>
      <%= render "layouts/navbar" %>
    <% end %>
    <!-- Flash notifications -->
    <div aria-live="polite" aria-atomic="true" class="position-relative">
      <div id="flash_notifications" class="toast-container position-fixed top-0 end-0 p-3">
        <!-- Flash notifications will be injected here -->
        <%= render "layouts/flash_notifications" %>
      </div>
    </div>
    <div class="container-fluid min-vh-100 mb-2">
      <%= yield %>
    </div>
    <%= turbo_frame_tag "remote_modal", target: "_top" %>
  </body>
</html>
