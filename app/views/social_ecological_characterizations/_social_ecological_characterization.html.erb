<div class="card shadow mt-2">
  <div class="card-body">
    <div class="row align-items-center">
      <div class="col-12 col-md-3">
        <strong>Título:</strong> <%= social_ecological_characterization.title %>
      </div>

      <div class="col-12 col-md-3">
        <strong>Autores:</strong> <%= social_ecological_characterization.authors %>
      </div>

      <div class="col-12 col-md-1">
        <strong>Año:</strong> <%= social_ecological_characterization.year %>
      </div>

      <div class="col-12 col-md-3">
        <strong>Institución/Entidad:</strong> <%= social_ecological_characterization.institution %>
      </div>

      <div class="col-12 col-md-2 justify-content-end d-flex gap-2">
        <%= link_to social_ecological_characterization_path(social_ecological_characterization), data: { turbo_frame: "remote_modal" } do %>
          <div class="btn btn-info">
            <i class="bi bi-eye"></i>
          </div>
        <% end %>
        <%= link_to edit_social_ecological_characterization_path(social_ecological_characterization), data: { turbo_frame: "remote_modal" } do %>
          <div class="btn btn-secondary">
            <i class="bi bi-pencil-square"></i>
          </div>
        <% end %>
        <%= link_to social_ecological_characterization_path(social_ecological_characterization), data: { turbo_method: :delete , turbo_confirm: t("common.form.confirm_delete")} do %>
          <div class="btn btn-danger">
            <i class="bi bi-trash"></i>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>