<h2>Olvidé mi contraseña</h2>

<%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "container"}) do |f| %>
  <%= f.error_notification %>

  <div class="form-inputs">
    <%= f.input :email,
                label: t("devise.form.email"),
                required: true,
                autofocus: true,
                input_html: { autocomplete: "email" } %>
  </div>

  <div class="form-actions">
    <%= f.button :submit, t("devise.form.send_password_reset_instructions"), class: "btn btn-primary mt-2" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
