<div class="d-flex align-items-center justify-content-center min-vh-100 min-vw-70">
  <div class="container card p-4 shadow" style="max-width: 400px;">
    <h2>Registrarse</h2>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "form container" }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs continer">
        <%= f.input :email,
                    label: t("devise.form.email"),
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email" }%>
        <%= f.input :password,
                    label: t("devise.form.password"),
                    required: true,
                    hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password" } %>
        <%= f.input :password_confirmation,
                    label: t("devise.form.password_confirmation"),
                    required: true,
                    input_html: { autocomplete: "new-password" } %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, t("devise.form.sign_up"), class: "btn btn-primary mt-2" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
