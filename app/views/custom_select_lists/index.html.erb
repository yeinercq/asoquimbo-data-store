
<div class="header mt-3">
  <h1>LISTAS DE SELECCIÓN CONFIGURABLES</h1>
  <div class="d-flex justify-content-start gap-2">
    <%= link_to new_custom_select_list_path, class: "btn btn-primary", data: { turbo_frame: dom_id(CustomSelectList.new) } do %>
      <i class="bi bi-plus-circle-fill"></i> Nueva lista
    <% end %>
  </div>
</div>

<div class="container">
  <%= turbo_frame_tag CustomSelectList.new %>

  <%= turbo_frame_tag "custom_select_lists", class: "row row-cols-md-2 mb-4"  do %>
    <%= render @custom_select_lists %>
  <% end %>
</div>
