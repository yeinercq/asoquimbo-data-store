<%= turbo_frame_tag custom_select_list, class: "col-md-6 mt-2" do %>
  <div class="card shadow">
    <div class="card-header">
      Listas de opciones para <strong><%= t("activerecord.models.#{custom_select_list.model_name_association}.others") %></strong>
      <%= link_to new_custom_select_list_custom_option_list_path(custom_select_list), data: { turbo_frame: dom_id(custom_select_list, dom_id(CustomOptionList.new)) } do %>
        <div class="btn btn-primary">
          <i class="bi bi-plus-circle-fill"></i> Opciones
        </div>
      <% end %>
    </div>
    <div class="card-body">
      <%= turbo_frame_tag custom_select_list, dom_id(CustomOptionList.new) %>
      <%= turbo_frame_tag dom_id(custom_select_list, "custom_option_lists"), class: "row" do %>
        <% custom_select_list.custom_option_lists.ordered.each do |option_list| %>
          <%= render "custom_option_lists/custom_option_list", custom_option_list: option_list %>
        <% end %>
      <% end %>
    </div>
    <div class="card-footer">
      <div class="col d-flex justify-content-end gap-2">
        <%= link_to custom_select_list_path(custom_select_list), data: { turbo_method: :delete , turbo_confirm: t("common.form.confirm_delete")} do %>
          <div class="btn btn-danger">
            <i class="bi bi-trash"></i>
          </div>
        <% end %>
        <%= link_to new_custom_select_list_custom_option_list_path(custom_select_list), data: { turbo_frame: dom_id(custom_select_list, dom_id(CustomOptionList.new)) } do %>
          <div class="btn btn-primary">
            <i class="bi bi-plus-circle-fill"></i> Opciones
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %> 