<%= turbo_frame_tag monthly_report do %>
  <div class="container-fluid" style="min-width: 1200px;">
    <div class="row border rounded mt-2 py-2 align-items-center shadow">
      <div class="col-4"><small><%= monthly_report.user.name %></small></div>
      <div class="col-2"><small><%= monthly_report.date_period.strftime("%B, %Y") %></small></div>
      <div class="col-2"><small><%= monthly_report.created_at.strftime("%Y-%m-%d") %></small></div>
      <div class="col-2"><small><%= @custom_select_list.custom_option_name(monthly_report.component) %></small></div>
      <div class="col-2 justify-content-end d-flex gap-2">
        <%= link_to monthly_report_path(monthly_report), data: { turbo_frame: "_top" } do %>
          <div class="btn btn-info">
            <i class="bi bi-eye"></i>
          </div>
        <% end %>
        <% if can? :update, monthly_report %>
          <%= link_to edit_monthly_report_path(monthly_report) do %>
            <div class="btn btn-secondary">
              <i class="bi bi-pencil"></i>
            </div>
          <% end %>
        <% end %>
        <% if can? :destroy, monthly_report %>
          <%= link_to monthly_report_path(monthly_report), data: { turbo_method: :delete , turbo_confirm: t("common.form.confirm_delete")} do %>
            <div class="btn btn-danger">
              <i class="bi bi-trash"></i>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
