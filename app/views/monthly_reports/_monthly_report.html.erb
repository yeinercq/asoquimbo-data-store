<div class="card shadow mt-2">
  <div class="card-body">
    <div class="row align-items-center">
      <div class="col-12 col-md-3">
        <strong>Responsable:</strong> <%= monthly_report.user.email %>
      </div>

      <div class="col-12 col-md-3">
        <strong>Periodo reportado:</strong> <%= monthly_report.date_period.strftime("%B, %Y") %>
      </div>

      <div class="col-12 col-md-4">
        <strong>Componente:</strong> <%= @custom_select_list.custom_option_name(monthly_report.component) %>
      </div>

      <div class="col-12 col-md-2 justify-content-end d-flex gap-2">
        <%= link_to monthly_report_path(monthly_report), data: { turbo: false } do %>
          <div class="btn btn-info">
            <i class="bi bi-eye"></i>
          </div>
        <% end %>
        <%= link_to edit_monthly_report_path(monthly_report) do %>
          <div class="btn btn-secondary">
            <i class="bi bi-pencil"></i>
          </div>
        <% end %>
        <%= link_to monthly_report_path(monthly_report), data: { turbo_method: :delete , turbo_confirm: t("common.form.confirm_delete")} do %>
          <div class="btn btn-danger">
            <i class="bi bi-trash"></i>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>