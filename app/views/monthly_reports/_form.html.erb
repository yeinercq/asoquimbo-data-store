<%= simple_form_for monthly_report, html: { class: "form card shadow mt-2" } do |f| %>
  <div class="card-body">
    <%= form_error_notification(monthly_report) %>

    <div class="mb-3">
      <div class="row">
        <%= f.input :date_period, prompt: t("common.form.select_an_option"), input_html: { class: "form-control" }, wrapper_html: { class: 'col' } %>
        <%= f.input :component, collection: custom_options_for_select(:component), label_method: :first, value_method: :second, prompt: t("common.form.select_an_option"), input_html: { class: "form-select" },  wrapper_html: { class: 'col' } %>
      </div>
    </div>

    <div class="col-12 d-flex justify-content-end gap-2">
      <%= link_to t("common.cancel"), monthly_reports_path, class: "btn btn-secondary" %>
      <%= f.submit t("common.accept"), class: "btn btn-warning"%>
    </div>
  </div>
<% end %>